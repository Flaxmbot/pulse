// Test for many constants (should exceed 256)
let arr = [];

// Add 300 constants
for i in 0..300 {
    push(arr, i);
}

println("Created array with", len(arr), "constants");
println("First element:", arr[0]);
println("Last element:", arr[299]);

// Test that all values are correct
let error_found = false;
let idx = 0;
while idx < len(arr) {
    if arr[idx] != idx {
        println("ERROR: arr[", idx, "] =", arr[idx], "but expected", idx);
        error_found = true;
    }
    idx = idx + 1;
}

if !error_found {
    println("SUCCESS: All", len(arr), "constants are correct!");
} else {
    println("FAILURE: Some constants are incorrect");
}