// Test 6: Linked List Simulation
println("\n--- Test 6: Linked List Simulation ---");
let node3 = {"value": 30, "next": null};
let node2 = {"value": 20, "next": node3};
let node1 = {"value": 10, "next": node2};

println("Linked list traversal:");
let current = node1;
let count = 0;
while (current != null and count < 5) {
    println("Node value:", current["value"]);
    current = current["next"];
    count = count + 1;
}

// Test 7: Tree Structure (Binary Tree)
println("\n--- Test 7: Binary Tree Structure ---");
let tree = {
    "value": 10,
    "left": {
        "value": 5,
        "left": {"value": 3, "left": null, "right": null},
        "right": {"value": 7, "left": null, "right": null}
    },
    "right": {
        "value": 15,
        "left": {"value": 12, "left": null, "right": null},
        "right": {"value": 20, "left": null, "right": null}
    }
};

// DFS traversal function
def dfs(node) {
    if (node == null) {
        return;
    }
    print(node["value"], " ");
    dfs(node["left"]);
    dfs(node["right"]);
}

print("DFS traversal: ");
dfs(tree);
println();

// Test 8: Recursion
println("\n--- Test 8: Recursive Functions ---");
def factorial(n) {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

let fact5 = factorial(5);
println("Factorial of 5:", fact5);

def fibonacci(n) {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

let fib10 = fibonacci(10);
println("10th Fibonacci number:", fib10);

// Test 9: Object-Oriented Programming Concepts
println("\n--- Test 9: OOP Concepts (Simulated) ---");
def create_person(name, age) {
    return {
        "name": name,
        "age": age,
        "greet": fn(self) { return "Hello, I am " + self["name"]; },
        "have_birthday": fn(self) { self["age"] = self["age"] + 1; }
    };
}

let person = create_person("Charlie", 28);
println("Person name:", person["name"]);
println("Person age:", person["age"]);
println("Greeting:", person["greet"](person));

person["have_birthday"](person);
println("Age after birthday:", person["age"]);

// Test 10: Complex Algorithms - BFS Simulation
println("\n--- Test 10: BFS Simulation ---");
def bfs(graph, start_node) {
    let visited = {};
    let queue = [];
    push(queue, start_node);
    visited[start_node] = true;
    
    print("BFS traversal: ");
    while (len(queue) > 0) {
        let current = queue[0];
        // Remove first element (simulate queue dequeue)
        let new_queue = [];
        let i = 1;
        while (i < len(queue)) {
            push(new_queue, queue[i]);
            i = i + 1;
        }
        queue = new_queue;
        
        print(current, " ");
        
        // Visit neighbors (simulated)
        if (current == "A") {
            if (!visited["B"]) { 
                push(queue, "B"); 
                visited["B"] = true; 
            }
            if (!visited["C"]) { 
                push(queue, "C"); 
                visited["C"] = true; 
            }
        } else if (current == "B") {
            if (!visited["D"]) { 
                push(queue, "D"); 
                visited["D"] = true; 
            }
        } else if (current == "C") {
            if (!visited["E"]) { 
                push(queue, "E"); 
                visited["E"] = true; 
            }
        }
    }
    println();
}

// Simulate a graph: A -> B, C; B -> D; C -> E
bfs(null, "A");

// Test 11: Performance with Large Data Sets
println("\n--- Test 11: Large Data Set Performance ---");
let large_array = [];
let i = 0;
while (i < 100) {
    push(large_array, i * i);  // Store squares
    i = i + 1;
}

println("Large array size:", len(large_array));
println("First element:", large_array[0]);
println("Middle element:", large_array[49]);
println("Last element:", large_array[99]);

// Test sum calculation
let sum = 0;
i = 0;
while (i < len(large_array)) {
    sum = sum + large_array[i];
    i = i + 1;
}
println("Sum of large array:", sum);

