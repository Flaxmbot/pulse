// Comprehensive Pulse Program - Demonstrates all major language features
let integerNumber = 42;
let floatNumber = 3.14159;

let doubleQuoteString = "Double quoted string";
let isTrue = true;
let isFalse = false;
let nullValue = nil;

// Type checking
println("Type checking test:");
