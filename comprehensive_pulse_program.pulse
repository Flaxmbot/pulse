println("Type of floatNumber:", type_of(floatNumber));
println("Type of doubleQuoteString:", type_of(doubleQuoteString));
println("Type of isTrue:", type_of(isTrue));
println("Type of nullValue:", type_of(nullValue));

// Arrays and objects
let numbersArray = [1, 2, 3, 4, 5];
