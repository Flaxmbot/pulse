// Test class syntax
class TestClass {
    fn init(value) {
        let obj = {
            "value": value,
            "line": 0,
            "column": 0
        };
        return obj;
    }
    
    fn set_line(obj, line_num) {
        obj["line"] = line_num;
        return obj;
    }
    
    fn set_column(obj, col_num) {
        obj["column"] = col_num;
        return obj;
    }
}

// Test creating an instance
let test_obj = TestClass.init(42);
TestClass.set_line(test_obj, 10);
TestClass.set_column(test_obj, 5);

print("Test object:", test_obj);

// Define a simple AST node using maps
fn create_ast_node(type_name, value, line, col) {
    return {
        "type": type_name,
        "value": value,
        "line": line,
        "column": col
    };
}

let literal_node = create_ast_node("literal", 42, 1, 1);
print("Literal node:", literal_node);

print("Class syntax test completed");