println("\n--- Testing Memory Allocation Stress ---");
let containers = [];
i = 0;
while (i < 100) {
    let container = {
        "id": i,
        "data": [],
        "metadata": {
            "created_at": i * 1000,
            "tags": [],
            "config": {
                "enabled": i % 2 == 0,
                "priority": i % 5,
                "name": "container_" + i
            }
        }
    };
    
    // Add some data to each container
    let j = 0;
    while (j < 5) {
        push(container["data"], i * 10 + j);
        push(container["metadata"]["tags"], "tag_" + j);
        j = j + 1;
    }
    
    push(containers, container);
    i = i + 1;
}

println("Created", len(containers), "containers with nested data");
println("First container data length:", len(containers[0]["data"]));
println("First container tag count:", len(containers[0]["metadata"]["tags"]));
println("Last container priority:", containers[99]["metadata"]["config"]["priority"]);

// Verify some values
if (len(containers) == 100 and len(containers[50]["data"]) == 5) {
    println("SUCCESS: Memory allocation and nested structures working correctly");
} else {
    println("FAILURE: Issues with memory allocation or nested structures");
}

println("\n=== Expanded Constant Pool Test Completed Successfully! ===");
println("Phase 0 implementation verified with over 400 constants in the expanded pool.");
println("Constant pool capacity has been successfully increased beyond 256 entries.");