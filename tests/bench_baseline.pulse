// Baseline benchmark workload used by CLI benchmark and CI performance gate.

let n = 20000;
let i = 0;
let acc = 0;

while (i < n) {
    acc = acc + (i % 7);
    if ((i % 11) == 0) {
        acc = acc + 3;
    }
    i = i + 1;
}

let values = [1, 2, 3, 4, 5];
let j = 0;
while (j < 5000) {
    push(values, j);
    let popped = pop(values);
    j = j + 1;
}

print(acc, len(values));
