// --- Basic Class ---
print "--- Testing Basic Class ---";
class Point {
    fn init(x, y) {
        this.x = x;
        this.y = y;
    }

    fn distance_squared() {
        return this.x * this.x + this.y * this.y;
    }
    
    fn set_x(new_x) {
        print "Inside set_x";
        this.x = new_x;
    }
}

let p = Point(3, 4);
print "Point created";

// Manually checking p.x
let px = p.x;
print "p.x = " + to_string(px);

let py = p.y;
print "p.y = " + to_string(py);

let dist = p.distance_squared();
print "dist = " + to_string(dist);

p.set_x(10);
print "Called set_x(10)";
print "p.x after set = " + to_string(p.x);


// --- Inheritance ---
print "\n--- Testing Inheritance ---";
class Animal {
    fn speak() {
        return "Generic sound";
    }
    
    fn name() {
        return "Unknown";
    }
}

class Dog extends Animal {
    fn speak() {
        return "Woof";
    }
    
    fn generic_speak() {
        return super.speak();
    }
}

let d = Dog();
print "Dog created";
print "d.speak() = " + d.speak();
print "d.name() = " + d.name();
print "d.generic_speak() = " + d.generic_speak();

print "\n=== OOPS Test Completed Successfully ===";
