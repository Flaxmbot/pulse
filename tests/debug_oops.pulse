
print "Step 1: Start";

class Test {
    fn init(val) {
        print "Init called with " + to_string(val);
        this.val = val;
    }

    fn get_val() {
        return this.val;
    }

    fn set_val(new_val) {
        print "Setting val to " + to_string(new_val);
        this.val = new_val;
    }
}

print "Step 2: Class defined";

let t = Test(42);
print "Step 3: Instance created";

let v = t.get_val();
print "Step 4: Value retrieved: " + to_string(v);

t.set_val(100);
print "Step 5: Value set to 100";

let v2 = t.get_val();
print "Step 6: Value retrieved again: " + to_string(v2);
