println("Starting GC Stress Test...");
let start_time = clock();

let i = 0;
while (i < 10000) {
    // Create string garbage
    let s = "garbage_" + to_string(i);
    
    // Create list garbage
    let l = [s, i, "more data"];
    
    // Create map garbage
    let m = {"key": s, "val": l};
    
    if (i % 1000 == 0) {
        println("Iteration: " + to_string(i));
        gc(); 
    }
    i = i + 1;
}

println("Finished loop.");
let end_time = clock();
println("Time taken: " + to_string(end_time - start_time) + "s");

println("Final GC...");
gc();
println("GC Stress Test PASSED.");
