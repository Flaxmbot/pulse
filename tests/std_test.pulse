import "std/functional";

println("Testing Standard Library...");

// Test map
let nums = [1, 2, 3, 4, 5];
println("Original: " + to_string(nums));

let doubled = map(nums, fn(x) { return x * 2; });
println("Doubled: " + to_string(doubled));

// Test filter
let evens = filter(nums, fn(x) { return (x % 2) == 0; });
println("Evens: " + to_string(evens));

// Test reduce
let sum = reduce(nums, fn(acc, x) { return acc + x; }, 0);
println("Sum: " + to_string(sum));

if (sum == 15) {
    println("StdLib Tests Passed!");
} else {
    println("StdLib Tests Failed!");
}
