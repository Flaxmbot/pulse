print("Benchmarking 1M Actor Spawns...");
let start = current_timestamp_millis();
let i = 0;
while (i < 100000) {
    // testing 100K first to see if it works, then 1M
    spawn(fn() {
        let x = 1;
    });
    i = i + 1;
}
let end = current_timestamp_millis();
print("Time to spawn 100,000 actors: " + to_string(end - start) + "ms");
