println("Testing Networking...");
println("Resolving google.com...");
let ips = dns_resolve("google.com");
println("IPs: " + to_string(ips));

println("Testing HTTP GET...");
let response = http_get("https://httpbin.org/get");
println("Response received. Length: " + to_string(len(response)));

if (string_contains(response, "httpbin.org")) {
    println("HTTP GET Passed");
} else {
    println("HTTP GET Failed or unexpected response");
}
