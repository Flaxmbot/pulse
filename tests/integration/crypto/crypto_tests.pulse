// Crypto & Serialization Tests

let data = { "key": "value" };
let bin = bincode_serialize(data);
assert_eq(type_of(bin), "List"); // represented as byte list for now

let back = bincode_deserialize(bin);
assert_eq(back["key"], "value");

let hash = sha256("test_string");
assert_eq(type_of(hash), "String");
