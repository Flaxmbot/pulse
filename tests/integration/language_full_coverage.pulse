let version_minor = 0;
print("Pulse", BUILD_TAG, version_major, version_minor);

let numbers = [1, 2, 3, 4, 5];
push(numbers, 6);
let first_number = numbers[0];
let last_number = pop(numbers);
print(first_number, last_number, len(numbers));

