let r = range(1, 5, 1);
let merged = list_concat([1, 2], [3, 4]);
print(len(r), len(merged), map_has_key(profile, "name"));

if (false) {
    // Input-taking and lower-level synchronization keywords are compile-checked,
    // but never executed in CI.
    let user_input = input_prompt("enter value: ");
    print(user_input);

    shared memory cache = 1;
    atomic lock_counter = 0;
    lock cache;
    unlock cache;
    fence;
    acquire;
    release;
}

assert_eq(type_of(BUILD_TAG), "String");
assert_eq(type_of(numbers), "List");
assert_ne(type_of(profile), "Nil");

print("full coverage complete");
