// Integration test: error handling with try/catch
fn risky_divide(a, b) {
    if (b == 0) {
        throw "Cannot divide by zero";
    }
    return a / b;
}

try {
    let result = risky_divide(10, 2);
    print(result);
} catch e {
    print("Error: " + e);
}

try {
    let result = risky_divide(10, 0);
    print("Should not see this");
} catch e {
    print("Caught error");
}

print("Program continues after catch");
