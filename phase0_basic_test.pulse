// Phase 0: Core Language Foundation - Basic Test Suite

println("=== Starting Phase 0 Basic Test Suite ===");

// Test 1: Basic Data Structures
println("\n--- Test 1: Basic Data Structures ---");
let arr = [1, 2, 3, 4, 5];
println("Array length:", len(arr));
println("First element:", arr[0]);
println("Last element:", arr[4]);

let map = {};
map["name"] = "Alice";
map["age"] = 30;
println("Map size:", len(map));
println("Name:", map["name"]);

// Test 2: Strings
println("\n--- Test 2: String Operations ---");
let str1 = "Hello";
let str2 = "World";
let combined = str1 + " " + str2;
println("Combined string:", combined);
println("String length:", len(combined));

// Test 3: Functions (named only for now)
println("\n--- Test 3: Function Operations ---");
def add(x, y) {
    return x + y;
}

let result = add(5, 3);
println("Named function result:", result);

// Test 4: Recursion
println("\n--- Test 4: Recursive Functions ---");
def factorial(n) {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

let fact5 = factorial(5);
println("Factorial of 5:", fact5);

// Test 5: Complex Nested Structures
println("\n--- Test 5: Complex Nested Structures ---");
let nested = {
    "users": [
        {"name": "Alice", "age": 30, "active": true},
        {"name": "Bob", "age": 25, "active": false}
    ],
    "config": {
        "debug": true,
        "version": "1.0",
        "features": ["feature1", "feature2", "feature3"]
    }
};

println("Nested structure users count:", len(nested["users"]));
println("First user name:", nested["users"][0]["name"]);
println("Config debug:", nested["config"]["debug"]);
println("Features count:", len(nested["config"]["features"]));

// Test 6: OOP Concepts (Simulated with objects)
println("\n--- Test 6: OOP Concepts (Simulated) ---");
def create_person(name, age) {
    return {
        "name": name,
        "age": age,
        "greet": fn(self) { return "Hello, I am " + self["name"]; },
        "have_birthday": fn(self) { self["age"] = self["age"] + 1; }
    };
}

let person = create_person("Charlie", 28);
println("Person name:", person["name"]);
println("Person age:", person["age"]);
println("Greeting:", person["greet"](person));

person["have_birthday"](person);
println("Age after birthday:", person["age"]);

// Test 7: Large Data Structures (Memory Management Test)
println("\n--- Test 7: Large Data Structures ---");
let large_array = [];
let i = 0;
while (i < 100) {
    push(large_array, i * i);  // Store squares
    i = i + 1;
}

println("Large array size:", len(large_array));
println("First element:", large_array[0]);
println("Middle element:", large_array[49]);
println("Last element:", large_array[99]);

// Test sum calculation
let sum = 0;
i = 0;
while (i < len(large_array)) {
    sum = sum + large_array[i];
    i = i + 1;
}
println("Sum of large array:", sum);

// Test 8: Complex Algorithms - Tree Traversal
println("\n--- Test 8: Tree Structure and Traversal ---");
let tree = {
    "value": 10,
    "left": {
        "value": 5,
        "left": {"value": 3, "left": nil, "right": nil},
        "right": {"value": 7, "left": nil, "right": nil}
    },
    "right": {
        "value": 15,
        "left": {"value": 12, "left": nil, "right": nil},
        "right": {"value": 20, "left": nil, "right": nil}
    }
};

// DFS traversal function
def dfs(node, visit_fn) {
    if (node == nil) {
        return;
    }
    visit_fn(node["value"]);
    dfs(node["left"], visit_fn);
    dfs(node["right"], visit_fn);
}

print("DFS traversal: ");
let values = [];
dfs(tree, fn(val) { push(values, val); print(val, " "); });
println();

// Test 9: Error Handling (Boundary Checks)
println("\n--- Test 9: Boundary Checks ---");
if (len(arr) > 0) {
    println("Safe access - first element:", arr[0]);
}
if (len(arr) > 10) {
    println("This shouldn't print");
} else {
    println("Correctly handled boundary condition");
}

// Test 10: Performance with Nested Operations
println("\n--- Test 10: Complex Nested Operations ---");
let complex_data = [
    {"id": 1, "items": [{"name": "item1", "tags": ["a", "b"]}, {"name": "item2", "tags": ["c", "d"]}]},
    {"id": 2, "items": [{"name": "item3", "tags": ["a", "c"]}, {"name": "item4", "tags": ["b", "d"]}]},
    {"id": 3, "items": [{"name": "item5", "tags": ["a", "d"]}, {"name": "item6", "tags": ["b", "c"]}]},
];

println("Complex data length:", len(complex_data));
println("First item in first group:", complex_data[0]["items"][0]["name"]);
println("Tags of second item in third group:", len(complex_data[2]["items"][1]["tags"]));

// Test 11: HashSets (using maps as sets)
println("\n--- Test 11: Set-like Operations ---");
let set = {};
set["apple"] = true;
set["banana"] = true;
set["cherry"] = true;
println("Set size:", len(set));
println("Contains apple:", set["apple"]);
println("Contains orange:", set["orange"]);

// Test 12: Linked List Simulation
println("\n--- Test 12: Linked List Simulation ---");
let node3 = {"value": 30, "next": nil};
let node2 = {"value": 20, "next": node3};
let node1 = {"value": 10, "next": node2};

println("Linked list traversal:");
let current = node1;
let count = 0;
while (current != nil and count < 5) {
    println("Node value:", current["value"]);
    current = current["next"];
    count = count + 1;
}

// Test 13: Multi-dimensional Arrays (nested lists)
println("\n--- Test 13: Multi-dimensional Arrays ---");
let matrix = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 9]
];

println("Matrix dimensions:", len(matrix), "x", len(matrix[0]));
println("Center element:", matrix[1][1]);
println("Bottom-right element:", matrix[2][2]);

// Test 14: Hashmaps with complex keys/values
println("\n--- Test 14: Complex Hashmap Operations ---");
let complex_map = {};
complex_map["user_1"] = {"id": 1, "profile": {"name": "Alice", "settings": {"theme": "dark"}}};
complex_map["user_2"] = {"id": 2, "profile": {"name": "Bob", "settings": {"theme": "light"}}};

println("Complex map size:", len(complex_map));
println("User 1 name:", complex_map["user_1"]["profile"]["name"]);
println("User 2 theme:", complex_map["user_2"]["profile"]["settings"]["theme"]);

println("\n=== All Phase 0 Basic Tests Completed Successfully! ===");
println("Core language features working:");
println("- Arrays, Lists, Strings, Hashmaps, Hashsets");
println("- Nested data structures and loops");
println("- Functions (named)");
println("- OOP concepts simulation");
println("- Complex algorithms");
println("- Memory management");