// Comprehensive Pulse Program - without actors
let integerNumber = 42;
let floatNumber = 3.14159;

let doubleQuoteString = "Double quoted string";
let isTrue = true;
let isFalse = false;
let nullValue = nil;

// Type checking
print("Type checking test:");
print("Type of integerNumber:", type_of(integerNumber));
print("Type of floatNumber:", type_of(floatNumber));
print("Type of doubleQuoteString:", type_of(doubleQuoteString));
print("Type of isTrue:", type_of(isTrue));
print("Type of nullValue:", type_of(nullValue));

// Arrays and objects
let numbersArray = [1, 2, 3, 4, 5];
let mixedArray = [1, "two", true, 3.14];

let person = {"name": "John Doe", "age": 30, "isStudent": false, "hobbies": ["reading", "coding", "hiking"], "address": {"street": "123 Main St", "city": "New York", "country": "USA"}};

// Linked list
class LinkedListNode {
    fn init(value) {
        this.value = value;
        this.next = nil;
    }
}

class LinkedList {
    fn init() {
        this.head = nil;
        this.tail = nil;
        this.size = 0;
    }

    fn add(value) {
        let newNode = LinkedListNode(value);
        if (this.head == nil) {
            this.head = newNode;
            this.tail = newNode;
        } else {
            this.tail.next = newNode;
            this.tail = newNode;
        }
        this.size = this.size + 1;
    }

    fn get(index) {
        if (index < 0 || index >= this.size) {
            throw "Index out of bounds";
        }
        let current = this.head;
        let i = 0;
        while (i < index) {
            current = current.next;
            i = i + 1;
        }
        return current.value;
    }
}

let linkedList = LinkedList();
linkedList.add(10);
linkedList.add(20);
linkedList.add(30);
linkedList.add(40);

// Binary tree
class TreeNode {
    fn init(value) {
        this.value = value;
        this.left = nil;
        this.right = nil;
    }
}

class BinaryTree {
    fn init() {
        this.root = nil;
    }

    fn insert(value) {
        let newNode = TreeNode(value);
        if (this.root == nil) {
            this.root = newNode;
        } else {
            this._insertRecursive(this.root, newNode);
        }
    }

    fn _insertRecursive(node, newNode) {
        if (newNode.value < node.value) {
            if (node.left == nil) {
                node.left = newNode;
            } else {
                this._insertRecursive(node.left, newNode);
            }
        } else {
            if (node.right == nil) {
                node.right = newNode;
            } else {
                this._insertRecursive(node.right, newNode);
            }
        }
    }

    fn inOrderTraversal() {
        let result = [];
        this._inOrderRecursive(this.root, result);
        return result;
    }

    fn _inOrderRecursive(node, result) {
        if (node != nil) {
            this._inOrderRecursive(node.left, result);
            push(result, node.value);
            this._inOrderRecursive(node.right, result);
        }
    }
}

let binaryTree = BinaryTree();
binaryTree.insert(50);
binaryTree.insert(30);
binaryTree.insert(70);
binaryTree.insert(20);
binaryTree.insert(40);

// Pattern matching
print("Pattern matching:");
let value = 42;
match value {
    0 => print("Value is zero"),
    1..10 => print("Value is between 1 and 10"),
    10..100 => print("Value is between 10 and 100"),
    _ => print("Value is 100 or greater")
};
print("");

// Error handling
print("Error handling:");
fn divide(a, b) {
    if (b == 0) {
        throw "Division by zero";
    }
    return a / b;
}

try {
    let result = divide(10, 0);
    print("Result:", result);
} catch error {
    print("Error:", error);
};
print("");

// Print binary tree traversal
print("");
print("Binary tree in-order traversal:");
let traversalResult = binaryTree.inOrderTraversal();
for (let i = 0; i < length(traversalResult); i = i + 1) {
    print(traversalResult[i]);
}

// Test linked list
print("");
print("Linked list:");
for (let i = 0; i < linkedList.size; i = i + 1) {
    print("Index", i, ":", linkedList.get(i));
}

// Print final message
print("");
print("=== All major language features demonstrated! ===");