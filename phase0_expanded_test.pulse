// Test for expanded constant pool (Phase 0 improvement)
// This creates many constants to test the expanded pool

// Create a large array with many constants
let values = [];
for i in 0..200 {
    push(values, i);
}

println("Created", len(values), "values in array");

// Test complex nested structures
let nested = {
    "level1": {
        "level2": {
            "level3": [1, 2, 3, 4, 5],
            "data": "deeply nested"
        }
    }
};

println("Nested structure created");

// Test large map
let map = {};
for i in 0..100 {
    let key = "key_" + i;
    let val = "value_" + i;
    map[key] = val;
}

println("Map created with", len(map), "entries");

println("Phase 0 test completed successfully!");