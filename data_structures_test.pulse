// Test for enhanced data structures and memory management (Phase 0 improvement)

// Test 1: Large list operations
println("Testing large list operations...");

let large_list = [];
for i in 0..1000 {
    push(large_list, i * i);  // Store squares
}

println("Created large list with", len(large_list), "elements");

// Verify some values
if large_list[10] == 100 && large_list[100] == 10000 && large_list[999] == 998001 {
    println("SUCCESS: Large list operations work correctly");
} else {
    println("FAILURE: Large list operations failed");
}

// Test 2: Complex nested structures
println("\nTesting complex nested structures...");

let nested = {
    "users": [
        {
            "id": 1,
            "name": "Alice",
            "settings": {
                "theme": "dark",
                "notifications": true,
                "preferences": ["email", "sms", "push"]
            }
        },
        {
            "id": 2,
            "name": "Bob",
            "settings": {
                "theme": "light",
                "notifications": false,
                "preferences": ["email"]
            }
        }
    ],
    "config": {
        "version": "1.0",
        "features": {
            "feature1": true,
            "feature2": false,
            "feature3": {
                "enabled": true,
                "options": ["opt1", "opt2", "opt3"]
            }
        }
    }
};

println("Complex nested structure created");

// Test 3: Map operations with many entries
println("\nTesting large map operations...");

let user_map = {};
for i in 0..500 {
    let user_key = "user_" + i;
    let user_name = "User " + i;
    user_map[user_key] = {
        "id": i,
        "name": user_name,
        "active": i % 2 == 0  // Even numbers are active
    };
}

println("Created user map with", len(user_map), "entries");

// Verify some values
if type_of(user_map["user_10"]) == "object" && user_map["user_10"]["id"] == 10 {
    println("SUCCESS: Large map operations work correctly");
} else {
    println("FAILURE: Large map operations failed");
}

// Test 4: Memory allocation stress test
println("\nTesting memory allocation...");

let containers = [];
for i in 0..100 {
    let container = {
        "index": i,
        "data": [],
        "metadata": {
            "created_at": i * 1000,
            "tags": []
        }
    };
    
    // Add some data to each container
    for j in 0..10 {
        push(container["data"], i * 10 + j);
        push(container["metadata"]["tags"], "tag_" + j);
    }
    
    push(containers, container);
}

println("Created", len(containers), "containers with nested data");

// Verify structure
if len(containers[50]["data"]) == 10 && len(containers[50]["metadata"]["tags"]) == 10 {
    println("SUCCESS: Memory allocation and nested structures work correctly");
} else {
    println("FAILURE: Memory allocation test failed");
}

println("\nPhase 0 enhanced data structures test completed!");