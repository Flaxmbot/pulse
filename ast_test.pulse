// Test for Pulse AST definitions
// Import doesn't exist so we just copy-paste or assume they are in the same scope
// For this test we will just include the ast.pulse content inline or run it as a single file

// --- AST Factory Functions --- (Inline for test)
fn literal_expr(value) { return { "type": "expr", "kind": "literal", "value": value }; }
fn variable_expr(name) { return { "type": "expr", "kind": "variable", "name": name }; }
fn binary_expr(left, op, right) { return { "type": "expr", "kind": "binary", "left": left, "operator": op, "right": right }; }
fn print_stmt(expr) { return { "type": "stmt", "kind": "print", "expression": expr }; }
fn block_stmt(stmts) { return { "type": "stmt", "kind": "block", "statements": stmts }; }

// --- Tests ---

print "Running AST tests...";

let lit = literal_expr(42);
assert_eq(lit["type"], "expr");
assert_eq(lit["kind"], "literal");
assert_eq(lit["value"], 42);

let var = variable_expr("x");
assert_eq(var["name"], "x");

let bin = binary_expr(lit, "+", var);
assert_eq(bin["operator"], "+");
assert_eq(bin["left"]["value"], 42);

let p_stmt = print_stmt(bin);
assert_eq(p_stmt["type"], "stmt");
assert_eq(p_stmt["kind"], "print");

let block = block_stmt([p_stmt]);
assert_eq(len(block["statements"]), 1);

print "AST tests passed!";
